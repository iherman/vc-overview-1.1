{
  "$id": "https://university.example/schemas/credential.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExampleAlumniCredential",
  "description": "Alumni Credential using JsonSchema",
  "type": "object",
  "properties": {
    "renderMethod": {
      "type": "object",
      "…"
    },
    "credentialSubject": {
      "type": "object",
      "properties": {
        "alumniOf": {
          "type": "string",
          "format": "url"
        },
        "confidenceMethod": {
          "type": "object",
          "…"
        }
      },
      "required": [
        "alumniOf"
      ]
    }
  }
}
